# Copy to `.env.local` (never commit real secrets)

# OpenAI (Whisper + analysis)
OPENAI_API_KEY=

# Prisma: use SCA_DATABASE_URL (NOT DATABASE_URL) — avoids conflicts with a global shell DATABASE_URL
# Default schema is PostgreSQL. For local SQLite only: copy prisma/schema.sqlite.prisma to schema.prisma and use:
# SCA_DATABASE_URL=file:./prisma/dev.db
SCA_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public

# Login cookie signing (≥16 chars). Generate: openssl rand -base64 32
AUTH_SECRET=BNBI5iZrs53DoWpPJF68WPJW6EzJCNrSKiVp+E5z3As=

# Optional: Vercel Blob for audio URLs
# BLOB_READ_WRITE_TOKEN=
